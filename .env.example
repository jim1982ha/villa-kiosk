# Villa Kiosk — environment defaults
# Copy to ".env" and fill in. All values are OPTIONAL: anything left blank can
# be entered at runtime in the Onboarding wizard / Settings. The token is best
# entered in the app rather than baked into the build.

# --- Home Assistant connection (Q3) ---
VITE_HA_URL=http://homeassistant.local:8123
VITE_HA_PORT=8123
# VITE_HA_TOKEN=eyJhbGciOi...   # long-lived token (optional, not recommended in builds)

# --- Villa location for sun tracking (Bali / TheLysHouse) ---
VITE_LAT=-8.3405
VITE_LNG=115.0920
